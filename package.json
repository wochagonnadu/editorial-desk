{
  "name": "editorialdesk",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "turbo run build",
    "check": "pnpm typecheck && pnpm lint",
    "check:ci": "pnpm check && pnpm test",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "prepare": "simple-git-hooks",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/node": "^20.17.24",
    "eslint": "^9.21.0",
    "prettier": "^3.5.2",
    "simple-git-hooks": "^2.13.1",
    "turbo": "^2.8.11",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.25.0"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm check"
  }
}
