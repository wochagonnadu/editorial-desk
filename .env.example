# PATH: .env.example
# WHAT: Shared environment variables template for local setup
# WHY:  Single reference for required API and web config values
# RELEVANT: specs/001-virtual-newsroom-mvp/quickstart.md,services/api/vercel.json,apps/web/src/services/api.ts

# Backend (services/api)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/editorialdesk
# Supabase session pooler example:
# DATABASE_URL=postgresql://postgres.<project_ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=verify-full
# Optional DB timeouts (recommended for Vercel/serverless fail-fast)
DB_CONNECT_TIMEOUT_MS=4000
DB_QUERY_TIMEOUT_MS=8000
DB_IDLE_TIMEOUT_MS=10000
DB_POOL_MAX=3
DB_OPERATION_TIMEOUT_MS=4000

NODEJS_HELPERS=0

EMAIL_PROVIDER=stub
EMAIL_API_KEY=replace-me
EMAIL_SEND_TIMEOUT_MS=8000
EMAIL_FROM=Editorial Desk <no-reply@vsche.ru>
EMAIL_INBOUND_ADDRESS=reply@vsche.ru
EMAIL_WEBHOOK_SECRET=replace-me
# Optional outbound TLS overrides for EMAIL_PROVIDER=resend
# EMAIL_TLS_CA_B64 must be base64 of PEM CA chain if your network uses custom TLS interception
EMAIL_TLS_CA_B64=
EMAIL_TLS_REJECT_UNAUTHORIZED=true

FACTCHECK_EVIDENCE_TABLE_ENABLED=false
FACTCHECK_EVIDENCE_TABLE_READ_PREFERRED=false

OPENROUTER_API_KEY=replace-me

JWT_SECRET=replace-me
MAGIC_LINK_TTL_HOURS=72
CRON_SECRET=replace-me

APP_URL=http://localhost:5173
API_URL=http://localhost:3000

# Dev auth bypass for API (optional for local development)
DEV_DISABLE_AUTH=false
DEV_AUTH_USER_ID=00000000-0000-0000-0000-000000000001
DEV_AUTH_COMPANY_ID=00000000-0000-0000-0000-000000000001
DEV_AUTH_ROLE=owner
DEV_AUTH_EMAIL=mail@mail.com

# Frontend (apps/web)
VITE_API_URL=http://localhost:3000
VITE_API_BASE_URL=http://localhost:3000

# Dev auth bypass for Web (optional for local development)
VITE_DEV_DISABLE_AUTH=false
VITE_DEV_AUTH_USER_ID=00000000-0000-0000-0000-000000000001
VITE_DEV_AUTH_COMPANY_ID=00000000-0000-0000-0000-000000000001
VITE_DEV_AUTH_ROLE=owner
VITE_DEV_AUTH_EMAIL=mail@mail.com

RESEND_API_KEY=replace-me
